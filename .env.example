# Required environment variables for hub-app
# Copy this file to .env and fill in your values. Never commit .env.

# Port the Express server listens on (default: 5000)
PORT=5053

# Node environment — set to "production" on Heroku
NODE_ENV=development

# Postgres connection string.
# Local example (Docker):  postgres://postgres:postgres@localhost:5454/hubapp
# Heroku adds this automatically when you provision the Postgres add-on.
DATABASE_URL=postgres://postgres:postgres@localhost:5454/hubapp

# Session signing secret — must be a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# On Heroku: heroku config:set SESSION_SECRET=<value>
SESSION_SECRET=replace-me-with-a-long-random-string

# Bcrypt hash of the admin password.
# Generate with: node scripts/hash-password.js your-password
# Copy the output here.
# On Heroku: heroku config:set ADMIN_PASSWORD_HASH=<value>
ADMIN_PASSWORD_HASH=

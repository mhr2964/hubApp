{
  "name": "hub-app",
  "version": "1.0.0",
  "scripts": {
    "dev": "nodemon server/index.js",
    "start": "node server/index.js",
    "client": "npm start --prefix client",
    "build": "npm run build --prefix client",
    "heroku-postbuild": "npm install --include=dev --prefix client && npm run build --prefix client",
    "lint": "eslint server/ && npm run lint --prefix client",
    "test": "npm run lint",
    "install-all": "npm install && npm install --prefix client",
    "db:migrate": "node-pg-migrate up --migrations-dir migrations",
    "db:rollback": "node-pg-migrate down --migrations-dir migrations"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.19.0",
    "marked": "^12.0.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "sanitize-html": "^2.17.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "nodemon": "^3.0.0"
  }
}
